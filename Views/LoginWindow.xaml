<Window x:Class="PCStoreApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему - АИС Магазин Кастомных ПК"
        Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Логотип -->
        <Border Grid.Row="0" 
                Background="{StaticResource PanelBrush}" 
                BorderBrush="{StaticResource BorderBrush}" 
                BorderThickness="1" 
                Height="60" 
                Margin="0,0,0,20">
            <TextBlock Text="ЛОГОТИП" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       FontSize="16" 
                       FontWeight="Bold" 
                       Foreground="{StaticResource TextBrush}"/>
        </Border>

        <!-- Форма входа -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Label Content="Логин:" Style="{StaticResource DefaultLabelStyle}"/>
            <TextBox Name="LoginTextBox" Style="{StaticResource DefaultTextBoxStyle}"/>
            
            <Label Content="Пароль:" Style="{StaticResource DefaultLabelStyle}"/>
            <PasswordBox Name="PasswordBox" 
                         Background="White"
                         BorderBrush="{StaticResource BorderBrush}"
                         BorderThickness="1"
                         Padding="5"
                         Margin="5"
                         FontSize="12"/>
            
            <TextBlock Name="ErrorTextBlock" 
                       Foreground="Red" 
                       Margin="5" 
                       TextWrapping="Wrap" 
                       Visibility="Collapsed"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="LoginButton" 
                    Content="Войти" 
                    Style="{StaticResource DefaultButtonStyle}" 
                    IsDefault="True"
                    Click="LoginButton_Click"/>
            <Button Name="CancelButton" 
                    Content="Отмена" 
                    Style="{StaticResource DefaultButtonStyle}" 
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>